# Application Configuration
APP_NAME="MainCore Backend"
APP_VERSION="1.0.0"
APP_ENV=development
PORT=3000
GIN_MODE=debug

# Database Configuration (PostgreSQL)
# Format: host=localhost user=root password=root dbname=starter_kit port=5432 sslmode=disable TimeZone=Asia/Jakarta
# Or standard connection string: postgres://user:password@localhost:5432/dbname
DATABASE_URL=postgres://root:root@localhost:5432/maincore_db?sslmode=disable

# Redis Configuration (Used for Asynq task queue)
REDIS_HOST=localhost
REDIS_PORT=6379

# Authentication Configuration
AUTH_JWT_SECRET=your_super_secret_jwt_key

# Storage Configuration (AWS S3 Compatible)
S3_ENDPOINT=https://s3.ap-southeast-1.amazonaws.com
S3_BUCKET=your-bucket-name
S3_REGION=ap-southeast-1
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key
S3_FORCE_PATH_STYLE=false
FILE_SAVE_TO_BUCKET=true
